{
	"name": "reservation-system",
	"version": "1.0.0",
	"description": "",
	"main": "start.mjs",
	"scripts": {
		"prepare": "husky",
		"start": "node --import tsx/esm start.mjs",
		"dev": "node --watch --import tsx/esm start.mjs",
		"test": "./node_modules/.bin/playwright test",
		"test:ui": "./node_modules/.bin/playwright test --ui",
		"test:headed": "./node_modules/.bin/playwright test --headed",
		"test:debug": "./node_modules/.bin/playwright test --debug",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"backup": "node --import tsx/esm scripts/backup-db.ts",
		"format": "biome format --write .",
		"build": "tsc",
		"typecheck": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PanLuce/reservation-system.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"bugs": {
		"url": "https://github.com/PanLuce/reservation-system/issues"
	},
	"homepage": "https://github.com/PanLuce/reservation-system#readme",
	"engines": {
		"node": "20"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@playwright/test": "^1.57.0",
		"@types/node": "^25.0.10",
		"@types/nodemailer": "^7.0.5",
		"@types/xlsx": "^0.0.35",
		"c8": "^10.1.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"nodemon": "^3.1.11",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
	},
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.18.2",
		"@types/multer": "^2.0.0",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"express": "^5.2.1",
		"express-rate-limit": "8.5.2",
		"express-session": "^1.18.2",
		"helmet": "^8.1.0",
		"multer": "^2.0.2",
		"nodemailer": "^7.0.12",
		"tsx": "^4.21.0",
		"winston": "^3.19.0",
		"xlsx": "^0.18.5"
	}
}
